<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="12dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: icon + title + close -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <ImageView
                android:id="@+id/ivVerdictIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_warning"
                android:contentDescription="@string/overlay_verdict_icon_desc" />

            <TextView
                android:id="@+id/tvVerdictTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="@string/overlay_scanning"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_close"
                android:background="@android:color/transparent"
                android:contentDescription="@string/overlay_close_desc"
                android:padding="4dp" />
        </LinearLayout>

        <!-- URL being scanned -->
        <TextView
            android:id="@+id/tvUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text=""
            android:textSize="12sp"
            android:textColor="#555555"
            android:maxLines="2"
            android:ellipsize="middle"
            android:fontFamily="monospace" />

        <!-- Resolved URL row (shortlinks) -->
        <LinearLayout
            android:id="@+id/layoutResolvedUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/overlay_redirects_to"
                android:textSize="12sp"
                android:textColor="#555555"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/tvResolvedUrl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textColor="#B71C1C"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="middle"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Scanning spinner -->
        <LinearLayout
            android:id="@+id/layoutScanning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ProgressBar
                android:id="@+id/progressScanning"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/overlay_scanning_desc"
                android:textSize="13sp"
                android:textColor="#555555" />
        </LinearLayout>

        <!-- Verdict reason box -->
        <LinearLayout
            android:id="@+id/layoutVerdictReason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_verdict_reason"
            android:padding="10dp">

            <TextView
                android:id="@+id/tvReasonTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/overlay_why_title"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvReasons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#2A2A2A"
                android:lineSpacingMultiplier="1.5" />
        </LinearLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTrustDomain"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="start|center_vertical"
                android:text="@string/overlay_btn_trust"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnProceed"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:textColor="#1A1A1A"
                android:text="@string/overlay_btn_proceed" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBlock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/overlay_btn_block"
                android:backgroundTint="@color/danger_red"
                android:textColor="@color/white" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
